;PUNTO1
; Gramática BNF para notación prefija polaca
; <prefix-expr> ::= (prefix-list <expr>)
; <expr> ::= <const-exp> | <add-exp> | <diff-exp> | <mult-exp> | <div-exp>
; <const-exp> ::= (const-exp number)
; <add-exp> ::= (add-exp <expr> <expr>)
; <diff-exp> ::= (diff-exp <expr> <expr>)
; <mult-exp> ::= (mult-exp <expr> <expr>)
; <div-exp> ::= (div-exp <expr> <expr>)

;LISTAS
;DEFINICIONES

(define prefix-list-ls
  (lambda (e) (list 'prefix-list e)))

(define const-exp-ls
  (lambda (n) (list 'const-exp n)))

(define add-exp-ls
  (lambda (e1 e2) (list 'add-exp e1 e2)))

(define diff-exp-ls
  (lambda (e1 e2) (list 'diff-exp e1 e2)))

(define mult-exp-ls
  (lambda (e1 e2) (list 'mult-exp e1 e2)))

(define div-exp-ls
  (lambda (e1 e2) (list 'div-exp e1 e2)))

;PREDICADOS

(define prefix-list-ls?
  (lambda (e)
    (and (pair? e) (eqv? (car e) 'prefix-list))))

(define const-exp-ls?
  (lambda (e)
    (and (pair? e) (eqv? (car e) 'const-exp))))

(define add-exp-ls?
  (lambda (e)
    (and (pair? e) (eqv? (car e) 'add-exp))))

(define diff-exp-ls?
  (lambda (e)
    (and (pair? e) (eqv? (car e) 'diff-exp))))

(define mult-exp-ls?
  (lambda (e)
    (and (pair? e) (eqv? (car e) 'mult-exp))))

(define div-exp-ls?
  (lambda (e)
    (and (pair? e) (eqv? (car e) 'div-exp))))

;EXTRACTORES

(define prefix-list->expr
  (lambda (e)
    (if (prefix-list-ls? e)
        (cadr e)
        (eopl:error 'prefix-list->expr "No es un prefix-list: ~s" e))))

; Extractores para const-exp
(define const-exp->value
  (lambda (e)
    (if (const-exp-ls? e)
        (cadr e)
        (eopl:error 'const-exp->value "No es una const-exp: ~s" e))))

; Extractores para add-exp
(define add-exp->e1
  (lambda (e)
    (if (add-exp-ls? e)
        (cadr e)
        (eopl:error 'add-exp->left "No es una add-exp: ~s" e))))

(define add-exp->e2
  (lambda (e)
    (if (add-exp-ls? e)
        (caddr e)
        (eopl:error 'add-exp->right "No es una add-exp: ~s" e))))

; Extractores para diff-exp
(define diff-exp->e1
  (lambda (e)
    (if (diff-exp-ls? e)
        (cadr e)
        (eopl:error 'diff-exp->left "No es una diff-exp: ~s" e))))

(define diff-exp->e2
  (lambda (e)
    (if (diff-exp-ls? e)
        (caddr e)
        (eopl:error 'diff-exp->right "No es una diff-exp: ~s" e))))

; Extractores para mult-exp
(define mult-exp->e1
  (lambda (e)
    (if (mult-exp-ls? e)
        (cadr e)
        (eopl:error 'mult-exp->left "No es una mult-exp: ~s" e))))

(define mult-exp->e2
  (lambda (e)
    (if (mult-exp-ls? e)
        (caddr e)
        (eopl:error 'mult-exp->right "No es una mult-exp: ~s" e))))

; Extractores para div-exp
(define div-exp->e1
  (lambda (e)
    (if (div-exp-ls? e)
        (cadr e)
        (eopl:error 'div-exp->left "No es una div-exp: ~s" e))))

(define div-exp->e2
  (lambda (e)
    (if (div-exp-ls? e)
        (caddr e)
        (eopl:error 'div-exp->right "No es una div-exp: ~s" e))))


;EJEMPLOS
(define exp-ls-1
    (prefix-list-ls
     (mult-exp-ls
      (add-exp-ls
       (const-exp-ls 3)
       (const-exp-ls 2))
      (div-exp-ls
       (const-exp-ls 4)
       (diff-exp-ls
        (const-exp-ls 12)
        (const-exp-ls 8))))))

(define exp-ls-2
  (prefix-list-ls
   (mult-exp-ls
    (const-exp-ls 8)
    (const-exp-ls 8))))

(define exp-ls-3
  (prefix-list-ls
   (mult-exp-ls
    (mult-exp-ls
     (const-exp-ls 5)
     (const-exp-ls 8))
    (mult-exp-ls
     (const-exp-ls 9)
     (const-exp-ls 10)))))

;DATATYPES
; Gramática BNF mejorada:
; <prefix-not>   ::= (prefix-list <prefix-exp>)
; <prefix-exp>   ::= <const-exp>
;                 |  <add-exp>
;                 |  <diff-exp>
;                 |  <mult-exp>
;                 |  <div-exp>
;
; <const-exp>    ::= (const-exp <number>)
; <add-exp>      ::= (add-exp <prefix-exp> <prefix-exp>)
; <diff-exp>     ::= (diff-exp <prefix-exp> <prefix-exp>)
; <mult-exp>     ::= (mult-exp <prefix-exp> <prefix-exp>)
; <div-exp>      ::= (div-exp <prefix-exp> <prefix-exp>)

(define-datatype prefix-exp prefix-exp?
  (const-exp (value number?))
  (add-exp   (e1 prefix-exp?) (e2 prefix-exp?))
  (diff-exp  (e1 prefix-exp?) (e2 prefix-exp?))
  (mult-exp  (e1 prefix-exp?) (e2 prefix-exp?))
  (div-exp   (e1 prefix-exp?) (e2 prefix-exp?)))

(define-datatype prefix-list- prefix-list?
  (prefix-list (expr prefix-exp?)))

;structs
(define exp-dt-1
    (prefix-list
     (mult-exp
      (add-exp
       (const-exp 3)
       (const-exp 2))
      (div-exp
       (const-exp 4)
       (diff-exp
        (const-exp 12)
        (const-exp 8))))))

(define exp-dt-2
  (prefix-list
   (mult-exp
    (const-exp 8)
    (const-exp 8))))

(define exp-dt-3
  (prefix-list
   (mult-exp
    (mult-exp
     (const-exp 5)
     (const-exp 8))
    (mult-exp
     (const-exp 9)
     (const-exp 10)))))
